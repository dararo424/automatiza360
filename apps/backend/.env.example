# ================================
# AUTOMATIZA360 BACKEND - ENV VARS
# ================================
# Copy this file to .env and fill in your values
# Never commit .env to git

# --- Database ---
DATABASE_URL="postgresql://user:password@host:5432/automatiza360_dev"

# --- JWT ---
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# --- App ---
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_WHATSAPP_NUMBER="+14155238886"  # sandbox: +14155238886 | production: tu número aprobado
TWILIO_ENV="sandbox"                   # "sandbox" o "production"

# --- Wompi (Pagos Colombia) ---
# Sandbox: https://sandbox.wompi.co/v1  |  Producción: https://production.wompi.co/v1
WOMPI_BASE_URL="https://sandbox.wompi.co/v1"
WOMPI_PUBLIC_KEY="pub_test_xxxxxxxxxxxxxxxx"
WOMPI_EVENTS_SECRET="your_wompi_events_secret"
WOMPI_INTEGRITY_SECRET="your_wompi_integrity_secret"

# --- AI Service ---
AI_SERVICE_URL="http://localhost:8000"

# --- Email (Resend) ---
# Crea tu cuenta en resend.com y verifica el dominio rgytgroup.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
SMTP_FROM="Automatiza360 <soporteautomatiza360@rgytgroup.com>"

# --- Anthropic (Admin/Support Chat) ---
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxx"

# --- Web Push (PWA Notifications) ---
VAPID_PUBLIC_KEY="your_vapid_public_key"
VAPID_PRIVATE_KEY="your_vapid_private_key"
VAPID_EMAIL="mailto:soporteautomatiza360@rgytgroup.com"

# --- Superadmin ---
SUPERADMIN_EMAIL="admin@automatiza360.com"
SUPERADMIN_PASSWORD="your_superadmin_password"
