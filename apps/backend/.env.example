# ================================
# AUTOMATIZA360 BACKEND - ENV VARS
# ================================
# Copy this file to .env and fill in your values
# Never commit .env to git

# --- Database ---
DATABASE_URL="postgresql://user:password@host:5432/automatiza360_dev"

# --- JWT ---
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# --- App ---
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_WHATSAPP_NUMBER="+14155238886"  # sandbox number for dev
TWILIO_ENV="sandbox"  # "sandbox" or "production"

# --- Wompi (Payments) ---
WOMPI_BASE_URL="https://sandbox.wompi.co/v1"  # use sandbox.wompi.co for dev/staging
WOMPI_EVENTS_SECRET="your_wompi_events_secret"
WOMPI_PUBLIC_KEY="pub_test_xxxxxxxxxxxxxxxx"  # test key for dev/staging

# --- AI Service ---
AI_SERVICE_URL="http://localhost:8000"

# --- Email (SMTP) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your@email.com"
SMTP_PASS="your_app_password"
SMTP_FROM="Automatiza360 <noreply@automatiza360.com>"

# --- Anthropic (Support Chat) ---
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxx"

# --- Web Push (PWA Notifications) ---
VAPID_PUBLIC_KEY="your_vapid_public_key"
VAPID_PRIVATE_KEY="your_vapid_private_key"
VAPID_EMAIL="mailto:admin@automatiza360.com"

# --- Superadmin ---
SUPERADMIN_EMAIL="admin@automatiza360.com"
SUPERADMIN_PASSWORD="your_superadmin_password"
