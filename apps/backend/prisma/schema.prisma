generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tenant = cada negocio cliente de Automatiza360
model Tenant {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  plan               Plan               @default(STARTER)
  industry           Industry
  active             Boolean            @default(true)
  trialEndsAt        DateTime?
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  twilioNumber       String?
  ownerPhone         String?
  subscriptionPlan   String?
  subscriptionEndsAt     DateTime?
  conversationCountMonth Int                @default(0)
  // Public profile fields
  descripcion       String?
  horario           String?
  logoUrl           String?
  direccion         String?
  ciudad            String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  users                User[]
  orders               Order[]
  products             Product[]
  tickets              Ticket[]
  cotizaciones         Cotizacion[]
  notificaciones       Notificacion[]
  suppliers            Supplier[]
  menusDia             MenuDia[]
  professionals        Professional[]
  services             Service[]
  appointments         Appointment[]
  paymentIntents       PaymentIntent[]
  conversations        Conversation[]
  contacts             Contact[]
  referralCode         ReferralCode?
  apiKeys              ApiKey[]
  gastos               Gasto[]
  campañas             Campaña[]
  garantias            Garantia[]
  automaciones         Automacion[]
  automacionEjecuciones AutomacionEjecucion[]
}

// Usuario dentro de un negocio
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(STAFF)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

// Pedidos (restaurante)
model Order {
  id        String      @id @default(cuid())
  number    Int
  status    OrderStatus @default(PENDING)
  total     Float
  notes     String?
  phone     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  items     OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Float
  name      String

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
}

// Productos / inventario (tienda tech + menú restaurante)
model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  cost        Float?
  stock       Int      @default(0)
  minStock    Int      @default(5)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

// Tickets de reparación (tienda tech)
model Ticket {
  id          String       @id @default(cuid())
  number      Int
  clientName  String
  clientPhone String
  device      String
  issue       String
  diagnosis   String?
  status      TicketStatus @default(RECEIVED)
  price       Float?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
}

model Cotizacion {
  id          String           @id @default(cuid())
  number      Int
  clientName  String
  clientPhone String?
  notes       String?
  total       Float
  status      CotizacionStatus @default(DRAFT)
  validUntil  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  items       CotizacionItem[]
}

model CotizacionItem {
  id           String     @id @default(cuid())
  quantity     Int
  price        Float
  name         String
  subtotal     Float
  cotizacionId String
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id])
}

model Notificacion {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  products  SupplierProduct[]

  @@unique([tenantId, name])
}

model SupplierProduct {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String?
  cost        Float
  price       Float
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model MenuDia {
  id        String         @id @default(cuid())
  fecha     DateTime       @default(now())
  activo    Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  platos    PlatoMenuDia[]
}

model PlatoMenuDia {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  disponible  Boolean  @default(true)
  menuDiaId   String
  menuDia     MenuDia  @relation(fields: [menuDiaId], references: [id], onDelete: Cascade)
}

// Citas / agenda (clínicas y salones de belleza)
model Professional {
  id           String        @id @default(cuid())
  name         String
  specialty    String?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  schedules    Schedule[]
  appointments Appointment[]
}

// Horario semanal del profesional (por día de semana)
model Schedule {
  id             String       @id @default(cuid())
  dayOfWeek      Int          // 0=Domingo … 6=Sábado
  startTime      String       // "08:00"
  endTime        String       // "17:00"
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

model Service {
  id           String        @id @default(cuid())
  name         String
  description  String?
  duration     Int           // minutos
  price        Float
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  appointments Appointment[]
}

model Appointment {
  id              String            @id @default(cuid())
  clientName      String
  clientPhone     String
  date            DateTime
  status          AppointmentStatus @default(SCHEDULED)
  notes           String?
  reminderSent    Boolean           @default(false)
  reminderSentAt  DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  serviceId       String
  service         Service           @relation(fields: [serviceId], references: [id])
  professionalId  String?
  professional    Professional?     @relation(fields: [professionalId], references: [id])
}

// Conversaciones WhatsApp (bandeja de mensajes)
model Conversation {
  id              String    @id @default(cuid())
  clientPhone     String
  clientName      String?
  lastMessage     String?
  lastMessageAt   DateTime?
  unreadCount     Int       @default(0)
  needsAttention  Boolean   @default(false)
  escalatedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  messages        Message[]

  @@unique([tenantId, clientPhone])
}

model Message {
  id             String           @id @default(cuid())
  body           String
  direction      MessageDirection
  createdAt      DateTime         @default(now())
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// CRM de contactos
model Contact {
  id          String   @id @default(cuid())
  phone       String
  name        String?
  email       String?
  notes       String?
  tags        String?
  puntos      Int      @default(0)
  puntosUsados Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, phone])
}

// Programa de referidos
model ReferralCode {
  id        String     @id @default(cuid())
  code      String     @unique
  tenantId  String     @unique
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  referrals Referral[]
  createdAt DateTime   @default(now())
}

model Referral {
  id             String       @id @default(cuid())
  referredTenantId String     @unique
  status         String       @default("PENDING")
  rewardGiven    Boolean      @default(false)
  createdAt      DateTime     @default(now())
  referralCodeId String
  referralCode   ReferralCode @relation(fields: [referralCodeId], references: [id])
}

// API pública (plan BUSINESS)
model ApiKey {
  id        String   @id @default(cuid())
  name      String
  keyHash   String   @unique
  keyPrefix String
  active    Boolean  @default(true)
  lastUsed  DateTime?
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model PaymentIntent {
  id                 String   @id @default(cuid())
  tenantId           String
  plan               String
  referencia         String   @unique
  monto              Int
  status             String   @default("PENDING")
  wompiTransactionId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// Enums
enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum Plan {
  STARTER
  PRO
  BUSINESS
}

enum Industry {
  RESTAURANT
  TECH_STORE
  CLINIC
  BEAUTY
  OTHER
}

enum Role {
  OWNER
  ADMIN
  STAFF
  SUPERADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum TicketStatus {
  RECEIVED
  DIAGNOSING
  WAITING_PARTS
  REPAIRING
  READY
  DELIVERED
  CANCELLED
}

enum CotizacionStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

// Gastos / egresos
model Gasto {
  id          String   @id @default(uuid())
  tenantId    String
  descripcion String
  monto       Float
  categoria   String
  fecha       DateTime @default(now())
  notas       String?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

// Campañas masivas de WhatsApp
enum CampañaStatus {
  BORRADOR
  ENVIANDO
  ENVIADA
  ERROR
}

model Campaña {
  id           String        @id @default(uuid())
  tenantId     String
  nombre       String
  mensaje      String
  status       CampañaStatus @default(BORRADOR)
  totalEnviado Int           @default(0)
  enviadaAt    DateTime?
  createdAt    DateTime      @default(now())
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
}

// Flujos de automatización WhatsApp
enum AutomacionTrigger {
  ORDER_DELIVERED
  APPOINTMENT_COMPLETED
  NEW_CONTACT
}

model Automacion {
  id          String                @id @default(uuid())
  tenantId    String
  nombre      String
  trigger     AutomacionTrigger
  activa      Boolean               @default(true)
  pasos       AutomacionPaso[]
  ejecuciones AutomacionEjecucion[]
  createdAt   DateTime              @default(now())
  tenant      Tenant                @relation(fields: [tenantId], references: [id])
}

model AutomacionPaso {
  id           String     @id @default(uuid())
  automacionId String
  orden        Int
  tipo         String     // "WAIT" | "SEND_WHATSAPP"
  config       Json       // { days: 2 } or { mensaje: "Hola {nombre}, ..." }
  automacion   Automacion @relation(fields: [automacionId], references: [id], onDelete: Cascade)
}

model AutomacionEjecucion {
  id            String     @id @default(uuid())
  automacionId  String
  tenantId      String
  contactPhone  String
  contactNombre String?
  pasoActual    Int        @default(0)
  scheduledAt   DateTime
  ejecutadaAt   DateTime?
  status        String     @default("PENDIENTE") // "PENDIENTE" | "COMPLETADA" | "ERROR"
  metadata      Json?
  automacion    Automacion @relation(fields: [automacionId], references: [id])
  tenant        Tenant     @relation(fields: [tenantId], references: [id])
  createdAt     DateTime   @default(now())
}

// Garantías de productos (tienda tech)
model Garantia {
  id               String   @id @default(uuid())
  tenantId         String
  clienteNombre    String
  clientePhone     String
  producto         String
  numeroSerie      String?
  fechaCompra      DateTime
  mesesGarantia    Int      @default(12)
  fechaVencimiento DateTime
  notas            String?
  ticketId         String?
  createdAt        DateTime @default(now())
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
}