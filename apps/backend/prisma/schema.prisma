generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tenant = cada negocio cliente de Automatiza360
model Tenant {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  plan               Plan               @default(STARTER)
  industry           Industry
  active             Boolean            @default(true)
  trialEndsAt        DateTime?
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  twilioNumber       String?
  ownerPhone         String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  users          User[]
  orders         Order[]
  products       Product[]
  tickets        Ticket[]
  cotizaciones   Cotizacion[]
  notificaciones Notificacion[]
  suppliers      Supplier[]
  menusDia       MenuDia[]
  professionals  Professional[]
  services       Service[]
  appointments   Appointment[]
}

// Usuario dentro de un negocio
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(STAFF)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

// Pedidos (restaurante)
model Order {
  id        String      @id @default(cuid())
  number    Int
  status    OrderStatus @default(PENDING)
  total     Float
  notes     String?
  phone     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  items     OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Float
  name      String

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
}

// Productos / inventario (tienda tech + menú restaurante)
model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  cost        Float?
  stock       Int      @default(0)
  minStock    Int      @default(5)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

// Tickets de reparación (tienda tech)
model Ticket {
  id          String       @id @default(cuid())
  number      Int
  clientName  String
  clientPhone String
  device      String
  issue       String
  diagnosis   String?
  status      TicketStatus @default(RECEIVED)
  price       Float?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
}

model Cotizacion {
  id          String           @id @default(cuid())
  number      Int
  clientName  String
  clientPhone String?
  notes       String?
  total       Float
  status      CotizacionStatus @default(DRAFT)
  validUntil  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  items       CotizacionItem[]
}

model CotizacionItem {
  id           String     @id @default(cuid())
  quantity     Int
  price        Float
  name         String
  subtotal     Float
  cotizacionId String
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id])
}

model Notificacion {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  products  SupplierProduct[]

  @@unique([tenantId, name])
}

model SupplierProduct {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String?
  cost        Float
  price       Float
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model MenuDia {
  id        String         @id @default(cuid())
  fecha     DateTime       @default(now())
  activo    Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  platos    PlatoMenuDia[]
}

model PlatoMenuDia {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  disponible  Boolean  @default(true)
  menuDiaId   String
  menuDia     MenuDia  @relation(fields: [menuDiaId], references: [id], onDelete: Cascade)
}

// Citas / agenda (clínicas y salones de belleza)
model Professional {
  id           String        @id @default(cuid())
  name         String
  specialty    String?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  schedules    Schedule[]
  appointments Appointment[]
}

// Horario semanal del profesional (por día de semana)
model Schedule {
  id             String       @id @default(cuid())
  dayOfWeek      Int          // 0=Domingo … 6=Sábado
  startTime      String       // "08:00"
  endTime        String       // "17:00"
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

model Service {
  id           String        @id @default(cuid())
  name         String
  description  String?
  duration     Int           // minutos
  price        Float
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  appointments Appointment[]
}

model Appointment {
  id             String            @id @default(cuid())
  clientName     String
  clientPhone    String
  date           DateTime
  status         AppointmentStatus @default(SCHEDULED)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  serviceId      String
  service        Service           @relation(fields: [serviceId], references: [id])
  professionalId String?
  professional   Professional?     @relation(fields: [professionalId], references: [id])
}

// Enums
enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum Plan {
  STARTER
  PRO
  BUSINESS
}

enum Industry {
  RESTAURANT
  TECH_STORE
  CLINIC
  BEAUTY
  OTHER
}

enum Role {
  OWNER
  ADMIN
  STAFF
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum TicketStatus {
  RECEIVED
  DIAGNOSING
  WAITING_PARTS
  REPAIRING
  READY
  DELIVERED
  CANCELLED
}

enum CotizacionStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}