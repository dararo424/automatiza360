# ================================
# AUTOMATIZA360 AI SERVICE - ENV VARS
# ================================

# --- Tenant Configuration ---
# JSON array of tenant configs, OR use BOT_EMAIL/BOT_PASSWORD for single tenant
# Para Instagram DMs agrega instagram_page_id y meta_page_access_token:
TENANT_CONFIG='[{"twilio_number":"+14155238886","bot_email":"bot@mybusiness.com","bot_password":"password","owner_phone":"+573001234567","instagram_page_id":"123456789012345","meta_page_access_token":"EAAxxxxx"}]'

# --- Single tenant fallback ---
BOT_EMAIL="bot@mybusiness.com"
BOT_PASSWORD="your_bot_password"

# --- Backend ---
BACKEND_URL="http://localhost:3000"

# --- Twilio ---
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_WHATSAPP_NUMBER="+14155238886"
WEBHOOK_URL="https://your-ai-service.up.railway.app/webhook"  # URL exacta que Twilio usa para firmar

# --- Google AI (Gemini) ---
GOOGLE_API_KEY="your_gemini_api_key"
GEMINI_API_KEY="your_gemini_api_key"  # alias — usa el mismo valor que GOOGLE_API_KEY

# --- Groq (Whisper — transcripción de notas de voz, free tier) ---
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxx"

# --- Owner phone per Twilio number ---
OWNER_PHONE="+573001234567"
# OWNER_PHONE_14155238886="+573001234567"  # per-number override

# --- Instagram DMs (Meta Graph API) ---
# Guía de configuración: https://developers.facebook.com/docs/messenger-platform/instagram
# 1. Crea una app en developers.facebook.com → Agregar producto → Messenger
# 2. Conecta tu cuenta de Instagram Business a una página de Facebook
# 3. Genera un Page Access Token con permiso instagram_manage_messages
# 4. Configura el webhook apuntando a: https://tu-ai-service.railway.app/instagram-webhook
# 5. En Campos del webhook selecciona: messages
INSTAGRAM_VERIFY_TOKEN="un_token_secreto_que_tu_eliges"  # el mismo que pones en el portal de Meta
META_APP_SECRET="tu_app_secret_de_meta"                  # Settings → Basic → App Secret

# --- Redis (persistencia del historial del bot entre reinicios) ---
# Si no se configura, el historial se guarda solo en memoria (se pierde al reiniciar)
# Railway: crea un plugin Redis y copia la URL que te da
# Upstash: https://upstash.com (free tier disponible)
REDIS_URL=""
# SESSION_TTL_SECONDS=86400  # tiempo de vida de sesiones (default 24h)
