# Twilio credentials (from twilio.com/console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API key (from aistudio.google.com)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NestJS backend URL
BACKEND_URL=https://backend-production-1a8c.up.railway.app

# Bot user credentials — create a STAFF user in the system for the bot
BOT_EMAIL=bot@yourdomain.com
BOT_PASSWORD=your-secure-bot-password

# Store display name shown in the bot's greeting.
# If not set, the bot fetches it automatically from the backend tenant profile.
BOT_STORE_NAME=
